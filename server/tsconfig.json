{
  "compilerOptions": {
    "target": "ES2022",                // Compile to modern JS
    "module": "ESNext",              // Node uses CommonJS
    "rootDir": "./src",                // Source files folder
    "outDir": "./dist",                // Compiled JS goes here
    "strict": true,                    // Enable strict type checking
    "esModuleInterop": true,           // Allow default imports from CommonJS
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,              // Skip type checking for node_modules
    "resolveJsonModule": true,         // Import JSON files as modules
    "types": ["node", "express"],      // Include type definitions
    "moduleResolution": "node",
    "noImplicitAny": true,             // Avoid implicit any types
    "allowJs": true                     // Allow compiling JS files if needed
  },
  "include": ["src/**/*.ts"],          // Compile all TS files in src
  "exclude": ["node_modules", "dist"]  // Ignore these folders
}
